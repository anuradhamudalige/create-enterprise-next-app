{
  "name": "{{appName}}",
  "version": "0.0.1-alpha.0",
  "private": true,
  "scripts": {
    "package:build": "node build",
    "dev": "next dev --webpack",
    "build": "next build",
    "build:prod": "npm run clean && cross-env NODE_ENV=production next build --webpack && npm run package:build",
    "start": "next start --webpack",
    "lint": "next lint",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest",
    "disable-telemetry": "npx next telemetry disable",
    "clean": "del-cli .next dist && npm run disable-telemetry"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "inversify": "^8.1.0",
    "newrelic": "^13.17.0",
    "next": "16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/newrelic": "^9.14.8",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.1",
    "fs-extra": "^11.3.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
